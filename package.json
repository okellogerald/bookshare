{
  "name": "bookshare",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "prod": "docker compose -f docker-compose.prod.yml up",
    "prod:build": "docker compose -f docker-compose.prod.yml up --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:generate": "bun --filter @bookshare/db run generate",
    "db:migrate": "bun --filter @bookshare/db run migrate",
    "db:push": "bun --filter @bookshare/db run push",
    "db:studio": "bun --filter @bookshare/db run studio",
    "import:validate": "bun run --cwd packages/importer src/cli.ts validate",
    "import:commit": "bun run --cwd packages/importer src/cli.ts commit",
    "import:report": "bun run --cwd packages/importer src/cli.ts report"
  }
}
