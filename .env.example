# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=booktrack
POSTGRES_PASSWORD=booktrack_dev
DATABASE_URL=postgresql://booktrack:booktrack_dev@localhost:5434/booktrack

# ─── PostgREST ────────────────────────────────────────────────
POSTGREST_DB_PASSWORD=postgrest_dev

# ─── Zitadel ─────────────────────────────────────────────────
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8085
ZITADEL_EXTERNALSECURE=false
ZITADEL_EXTERNAL_URL=http://localhost:8085
PUBLIC_ZITADEL_URL=http://localhost:8085
ZITADEL_ISSUER_URL=http://localhost:8085
