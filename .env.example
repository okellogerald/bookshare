ZITADEL_CLIENT_ID=
ZITADEL_JWT_SECRET=

# ─── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=booktrack
MINIO_ROOT_PASSWORD=booktrack_dev

# ─── App URLs ─────────────────────────────────────────────────
